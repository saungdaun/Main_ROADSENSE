<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mapFragment">

    <!-- ── Map ─────────────────────────────────────────────────────── -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="zaujaani.roadsensebasic.ui.map.MapFragment"
        android:label="@string/title_map">
        <action
            android:id="@+id/action_mapFragment_to_summaryFragment"
            app:destination="@id/summaryFragment" />
        <action
            android:id="@+id/action_mapFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_mapFragment_to_bluetoothFragment"
            app:destination="@id/bluetoothFragment" />
    </fragment>

    <!-- ── Summary ─────────────────────────────────────────────────── -->
    <fragment
        android:id="@+id/summaryFragment"
        android:name="zaujaani.roadsensebasic.ui.summary.SummaryFragment"
        android:label="@string/title_summary">
        <action
            android:id="@+id/action_summaryFragment_to_mapFragment"
            app:destination="@id/mapFragment" />
        <action
            android:id="@+id/action_summaryFragment_to_photoAnalysisFragment"
            app:destination="@id/photoAnalysisFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- ── Photo Analysis — post-survey job ────────────────────────── -->
    <fragment
        android:id="@+id/photoAnalysisFragment"
        android:name="zaujaani.roadsensebasic.ui.analysis.PhotoAnalysisFragment"
        android:label="Analisis Foto"
        tools:layout="@layout/fragment_photo_analysis">
        <argument
            android:name="sessionId"
            app:argType="long"
            android:defaultValue="-1L" />
        <argument
            android:name="roadName"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="sessionMode"
            app:argType="string"
            android:defaultValue="GENERAL" />
        <action
            android:id="@+id/action_photoAnalysisFragment_to_summaryFragment"
            app:destination="@id/summaryFragment"
            app:popUpTo="@id/summaryFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <!-- ── Settings ────────────────────────────────────────────────── -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="zaujaani.roadsensebasic.ui.settings.SettingsFragment"
        android:label="@string/title_settings">
        <action
            android:id="@+id/action_settingsFragment_to_mapFragment"
            app:destination="@id/mapFragment" />
    </fragment>

    <!-- ── Bluetooth ────────────────────────────────────────────────── -->
    <fragment
        android:id="@+id/bluetoothFragment"
        android:name="zaujaani.roadsensebasic.ui.bluetooth.BluetoothFragment"
        android:label="@string/menu_bluetooth"
        tools:layout="@layout/fragment_bluetooth">
        <action
            android:id="@+id/action_bluetoothFragment_to_mapFragment"
            app:destination="@id/mapFragment" />
    </fragment>

    <!-- ── About ────────────────────────────────────────────────────── -->
    <fragment
        android:id="@+id/aboutFragment"
        android:name="zaujaani.roadsensebasic.ui.about.AboutFragment"
        android:label="Tentang Aplikasi"
        tools:layout="@layout/fragment_about">
        <action
            android:id="@+id/action_aboutFragment_to_mapFragment"
            app:destination="@id/mapFragment" />
    </fragment>

</navigation>