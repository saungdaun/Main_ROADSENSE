<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="?attr/colorSurface"
        android:elevation="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="18sp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="8dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRoadName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Jalan"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tvMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Survei SDI"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ·  "
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"/>

                <TextView
                    android:id="@+id/tvPhotoCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20 foto"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"/>

            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnalyzeAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍 Analisis Semua"
            android:textSize="12sp"
            android:paddingHorizontal="12dp"/>

    </LinearLayout>

    <!-- Batch progress -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressBatch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:trackCornerRadius="0dp"/>

    <TextView
        android:id="@+id/tvBatchStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="11sp"
        android:textColor="?android:attr/textColorSecondary"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:visibility="gone"/>

    <!-- Summary chips -->
    <com.google.android.material.chip.ChipGroup
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        app:singleLine="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipDone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ 0 Selesai"
            android:textSize="11sp"
            style="@style/Widget.MaterialComponents.Chip.Filter"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipPending"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳ 0 Belum"
            android:textSize="11sp"
            style="@style/Widget.MaterialComponents.Chip.Filter"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipFailed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="❌ 0 Gagal"
            android:textSize="11sp"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Chip.Filter"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chipInvalid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⊘ 0 Bukan Jalan"
            android:textSize="11sp"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Chip.Filter"/>

    </com.google.android.material.chip.ChipGroup>

    <!-- Photo list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewPhotos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingVertical="4dp"
        android:clipToPadding="false"/>

</LinearLayout>