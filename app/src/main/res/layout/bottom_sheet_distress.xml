<?xml version="1.0" encoding="utf-8"?>
<!--
    bottom_sheet_distress.xml
    Dipakai oleh: DistressBottomSheet (SDI) DAN PciDistressBottomSheet (PCI)

    PERUBAHAN vs versi sebelumnya:
    - 4 quick button (btnQuick5 / btnQuick10 / btnQuick20 / btnQuick50) → DIHAPUS
    - Diganti: Dropdown preset nilai (actvQuantityPreset)
    - Ditambah: Field custom opsional (etCustomQuantity) di bawah dropdown
    - Alur input: pilih dari dropdown → nilai terisi otomatis
                  atau ketik di field custom → override nilai dropdown
    - Field etLengthArea DIHAPUS (diganti actvQuantityPreset + etCustomQuantity)
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Handle bar ── -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_bottom_sheet_handle"
            android:backgroundTint="@color/divider" />

        <!-- ── Judul ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Input Kerusakan Jalan"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp" />

        <!-- ══════════════════════════════════════════════
             SECTION 1: Jenis & Keparahan
             ══════════════════════════════════════════════ -->

        <!-- Dropdown: Jenis Kerusakan -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:hint="Jenis Kerusakan"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp">

            <AutoCompleteTextView
                android:id="@+id/actvDistressType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false"
                tools:text="Lubang" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Panduan Surveyor (muncul setelah jenis dipilih) -->
        <TextView
            android:id="@+id/tvSurveyorGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingMultiplier="1.3"
            android:background="@drawable/bg_guide_box"
            android:visibility="gone"
            tools:visibility="visible"
            tools:text="📐 Hitung luas: P × L lubang → m²&#10;   Contoh: 0.5m × 0.4m = 0.20 m²" />

        <!-- Dropdown: Tingkat Keparahan -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Tingkat Keparahan"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp">

            <AutoCompleteTextView
                android:id="@+id/actvSeverity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false"
                tools:text="Sedang" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══════════════════════════════════════════════
             SECTION 2: Panjang / Luas / Jumlah
             ══════════════════════════════════════════════ -->

        <!-- Header row: label + chip satuan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Panjang / Luas / Jumlah"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvUnitLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:background="@drawable/bg_chip_rounded"
                android:text="m / m²"
                tools:text="m²" />
        </LinearLayout>

        <!-- ── Dropdown Preset Nilai (BARU — ganti 4 tombol cepat) ── -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilQuantityPreset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:hint="Pilih nilai cepat"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp"
            app:startIconDrawable="@drawable/ic_speed"
            app:startIconTint="@color/primary">

            <AutoCompleteTextView
                android:id="@+id/actvQuantityPreset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false"
                tools:text="0.25 m²" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Divider antara preset dan custom ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:text="atau isi manual"
                android:textSize="11sp"
                android:textColor="@color/text_secondary" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/divider" />
        </LinearLayout>

        <!-- ── Field Custom Opsional (BARU) ── -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCustomQuantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Nilai lain (opsional)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCustomQuantity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:imeOptions="actionDone"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══════════════════════════════════════════════
             SECTION 3: Foto & Suara
             ══════════════════════════════════════════════ -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dokumentasi"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddPhoto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Foto"
                app:icon="@drawable/ic_camera"
                app:iconGravity="start"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVoice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/record_voice"
                app:icon="@drawable/ic_mic"
                app:iconGravity="start"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>

        <!-- Thumbnail foto preview -->
        <ImageView
            android:id="@+id/ivPhotoThumb"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginBottom="12dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_photo_thumb"
            android:visibility="gone"
            tools:visibility="visible"
            tools:src="@drawable/ic_camera"
            android:contentDescription="Preview foto kerusakan" />

        <!-- ══════════════════════════════════════════════
             SECTION 4: Catatan
             ══════════════════════════════════════════════ -->

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Catatan tambahan (opsional)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusBottomEnd="10dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:maxLines="4"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ══════════════════════════════════════════════
             SECTION 5: Simpan
             ══════════════════════════════════════════════ -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="180dp"
            android:layout_height="56dp"
            android:text="Simpan Kerusakan"
            android:textSize="15sp"
            android:layout_marginBottom="8dp"
            app:cornerRadius="12dp"/>


    </LinearLayout>
</ScrollView>